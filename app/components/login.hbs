<div class="container-abcd" id="container-abcd">
    <br>
<div class="containe" id="containe">
    <div class="container" id="container">
	<div class="form-container sign-up-container">
		<form {{on "submit" this.handleSignup}}>
			<h1>Create Account</h1>
			<div class="social-container">
				<a href="#" class="social"><i class="fab fa-facebook-f"></i></a>
				<a href="#" class="social"><i class="fab fa-google-plus-g"></i></a>
				<a href="#" class="social"><i class="fab fa-linkedin-in"></i></a>
			</div>
			<span>or use your email for registration</span>
			<input id="signupName" type="text" placeholder="Name" />
			<input id="signupEmail"type="email" placeholder="Email" />
			<input id="signupPSD" type="password" placeholder="Password" />
			<button type="submit" id="signUp">Sign Up</button>
				<div id="flash-messages-container1" style="background-color: lightgreen;color:aliceblue; padding: inherit;"></div>
			
		</form>
	</div>
	<div class="form-container sign-in-container">
		<form {{on "submit" this.handleLogin}}>
			<h1>User Login</h1>
			<div class="social-container">
				<a href="#" class="social"><i class="fab fa-facebook-f"></i></a>
				<a href="#" class="social"><i class="fab fa-google-plus-g"></i></a>
				<a href="#" class="social"><i class="fab fa-linkedin-in"></i></a>
			</div>
			<span>or use your account</span>
			<input id="signinEmail" type="email" placeholder="Email" />
			<input id="signinPSD" type="password" placeholder="Password" />
			<a href="#">Forgot your password?</a>
			<button type="submit" id="signIn" >Login</button>
			<div id="flash-messages-container" style="background-color: lightgreen;color:aliceblue;padding: inherit;"></div>
		</form>
	</div>
	<div class="overlay-container">
		<div class="overlay">
			<div class="overlay-panel overlay-left">
				<h1>Welcome Back!</h1>
				<p>To keep connected with us please login with your personal info</p>
				<button class="ghost" id="signIn" id="signUp"{{on "click" this.removeRightPanel}}>Sign In</button>
			</div>
			<div class="overlay-panel overlay-right">
				<h1>Welcome!</h1>
				<p>Please provide your personal details below to create an account and begin your journey with us.</p>
				<button class="ghost" id="signUp"  {{on "click" this.addRightPanel}}>Sign Up</button>
				
			</div>
		</div>
	</div>
</div>
</div>
</div>

{{yield}}